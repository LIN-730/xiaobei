# ============================================================
# 教务智能助手（小北）— 生产环境配置模板
# 复制此文件为 .env 并填入真实值后部署
# ============================================================

# --- 应用 ---
APP_NAME=教务智能助手
DEBUG=false
# 生产环境必须限制 CORS 源（多个用逗号分隔）
CORS_ORIGINS=https://your-domain.com

# --- 数据库 ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=edu_assistant
POSTGRES_USER=edu_user
# 使用强随机密码 (建议: openssl rand -base64 32)
POSTGRES_PASSWORD=change_me_to_strong_password

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- JWT ---
# 使用强随机密钥 (建议: openssl rand -base64 64)
JWT_SECRET_KEY=change_me_to_strong_jwt_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- AES 凭证加密 ---
# 使用 Fernet 兼容密钥 (建议: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
CREDENTIAL_ENCRYPTION_KEY=change_me_to_fernet_key

# --- LLM (豆包/DeepSeek API) ---
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# 必填: 填入你的 API Key
DOUBAO_DEFAULT_API_KEY=
DOUBAO_DEFAULT_MODEL=deepseek-v4-pro

# --- 教务系统 ---
EDU_BASE_URL=https://jwglxt.buct.edu.cn

# --- Celery (异步任务) ---
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# --- ChromaDB ---
CHROMADB_HOST=chromadb
CHROMADB_PORT=8001
CHROMA_PERSIST_DIR=/chroma/chroma
