# ============================================================
# 教务智能助手（小北）— 环境变量
# 复制为 .env 并填入实际值
# ============================================================

# --- 数据库 ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=edu_assistant
POSTGRES_USER=edu_user
POSTGRES_PASSWORD=change_me_strong_password

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Celery ---
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# --- JWT ---
JWT_SECRET_KEY=change_me_to_random_64_char_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- AES 凭证加密 ---
# 生成方式: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=change_me_fernet_key

# --- LLM (豆包API) ---
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_DEFAULT_API_KEY=
DOUBAO_DEFAULT_MODEL=deepseek-v4-pro

# --- 教务系统 ---
EDU_BASE_URL=https://jwglxt.buct.edu.cn

# --- 应用 ---
APP_NAME=教务智能助手
DEBUG=false
CORS_ORIGINS=*

# --- ChromaDB ---
CHROMA_PERSIST_DIR=/app/data/chroma
CHROMADB_HOST=chromadb
CHROMADB_PORT=8001
